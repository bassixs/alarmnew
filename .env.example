# Секреты. Скопируйте в .env (в .gitignore). Никогда не коммитьте реальные значения.

# LLM-шлюз (классификация + рерайт). По умолчанию AiTunnel (OpenAI-совместимый).
# Для обычного OpenAI: LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_BASE_URL=https://api.aitunnel.ru/v1

# Telegram: токен бота от @BotFather (публикация + бот-модератор)
TELEGRAM_BOT_TOKEN=

# Telethon (чтение публичных каналов-источников) — https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELETHON_SESSION=aialarm   # имя файла сессии

# MAX: токен бота от @MasterBot внутри MAX
MAX_BOT_TOKEN=

# База данных. Пилот: SQLite. Прод: postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./aialarm.db

# Путь к config.yaml
AIALARM_CONFIG=./config.yaml
